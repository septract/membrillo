    "./art/*": "./art/*.ts",
    "./walk": "./walk.ts",
    "./verify-kit": "./tools/drive/kit.mjs",
    "./vite": "./vite.ts",
    "./tsconfig.base.json": "./tsconfig.base.json"
  },
  "engines": {
    "node": ">=23"
  }
}
