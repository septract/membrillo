{
  "name": "membrillo-workspace",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": ["packages/membrillo", "games/*"],
  "scripts": {
    "dev": "npm run dev -w games/classic",
    "build": "npm run build -w games/classic",
    "preview": "npm run preview -w games/classic",
    "typecheck": "tsc --noEmit",
    "test": "node --test packages/membrillo/tools/core.test.ts packages/membrillo/tools/walk.test.ts packages/membrillo/tools/followers.test.ts",
    "validate": "STORIES_ROOT=games/classic/stories node packages/membrillo/tools/validate.ts",
    "fuzz": "STORIES_ROOT=games/classic/stories node packages/membrillo/tools/fuzz.ts",
    "check": "npm run typecheck && npm test && npm run validate && npm run fuzz",
    "drive": "node games/classic/drive.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
